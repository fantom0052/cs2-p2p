# Steam collector runtime config

# Steam Market search endpoint.
STEAM_HOME_URL=https://steamcommunity.com/
STEAM_BASE_URL=https://steamcommunity.com/market/search/render/
STEAM_IMAGE_BASE_URL=https://community.cloudflare.steamstatic.com/economy/image/
STEAM_APP_ID=730
STEAM_CURRENCY_ID=1
STEAM_CURRENCY=USD
STEAM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/140.0.0.0 Safari/537.36
STEAM_ACCEPT_LANGUAGE=ru-RU,ru;q=0.9,en-US;q=0.8,en;q=0.7
STEAM_COOKIE_SETTINGS=%7B%22version%22%3A1%2C%22preference_state%22%3A1%2C%22content_customization%22%3Anull%2C%22valve_analytics%22%3Anull%2C%22third_party_analytics%22%3Anull%2C%22third_party_content%22%3Anull%2C%22utm_enabled%22%3Atrue%7D
STEAM_BOOTSTRAP_COOKIES=true
STEAM_REQUEST_TIMEOUT=15s
STEAM_NORENDER=1
STEAM_DEFAULT_SORT_COLUMN=popular
STEAM_DEFAULT_SORT_DIR=desc
STEAM_DEFAULT_PAGE_SIZE=30
STEAM_SEARCH_DESCRIPTIONS=0

# Steam CS2 category filters. "any" means no filter.
STEAM_CATEGORY_ITEM_SET=any
STEAM_CATEGORY_PRO_PLAYER=any
STEAM_CATEGORY_STICKER_CAPSULE=any
STEAM_CATEGORY_TOURNAMENT=any
STEAM_CATEGORY_TOURNAMENT_TEAM=any
STEAM_CATEGORY_TYPE=any
STEAM_CATEGORY_WEAPON=any

# Kafka / Redpanda producer config.
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=raw.market.prices.steam
KAFKA_CLIENT_ID=steam-collector
KAFKA_ACKS=all
KAFKA_COMPRESSION=snappy
KAFKA_LINGER=100ms
KAFKA_BATCH_BYTES=1048576
KAFKA_RECORD_RETRIES=3

# Scheduler config.
SCHEDULER_INTERVAL=10s
SCHEDULER_RATE_LIMIT_PAUSE=10m
SCHEDULER_JITTER=10s
SCHEDULER_PAGE_SIZE=30
SCHEDULER_QUERY=
